main -> header(1)
header -> this(1)
this -> is(1)
is -> a(1)
a -> number(1), link(1), paragraph(1)
paragraph -> with(2)
with -> a(2), bold(1)
bold -> and(1)
and -> punctuation(1), italic(1)
italic -> text(1)
text -> first(1)
first -> item(1)
item -> with(1), second(1)
second -> item(1)
link -> https(1)
https -> example(1)
example -> com(1)
com -> another(1)
another -> paragraph(1)
number -> and(1)
punctuation -> hello(1)
hello -> world(1)
world -> (no transitions)
